{
  "expo": {
    "name": "Track",
    "slug": "track",
    "version": "0.1.0",
    "scheme": "track",
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "baseUrl": "/Track"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "bundleIdentifier": "com.defaltho.track",
      "supportsTablet": true
    },
    "android": {
      "package": "com.defaltho.track"
    }
  }
}
